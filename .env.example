# Locally built training image name. Compose project identities are fixed by
# repository commands: qwen-sft for training and qwen-vllm for inference.
LLAMAFACTORY_IMAGE=qwen-sft-llamafactory:local

# vLLM uses a pinned image tag. Override it deliberately after validating the
# replacement on the target GPU host.
VLLM_IMAGE=vllm/vllm-openai:v0.8.5

# Reproducible versions audited on the remote Tesla T4 host on 2026-07-19.
LLAMAFACTORY_BASE_IMAGE=hiyouga/llamafactory@sha256:cde9745570861693a8a0e7da6aa1a1fadde7c728b8ceeb189191ddc3a3a8d3f3
BITSANDBYTES_VERSION=0.49.2

# Bind the WebUI to loopback by default. Change deliberately when a protected
# reverse proxy or firewall is in place.
WEBUI_BIND_ADDRESS=127.0.0.1
WEBUI_PORT=7860

# Runtime state. These paths are not committed to Git.
HF_CACHE_DIR=/opt/vllm/hf-cache
DATA_DIR=./data
OUTPUT_DIR=/opt/llm-training/output

# vLLM serves the final DPO LoRA Adapter on top of the exact training base.
# VLLM_LORA_DIR is relative to OUTPUT_DIR and must not contain "..".
VLLM_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
VLLM_BASE_MODEL_NAME=qwen-base
VLLM_LORA_NAME=qwen-dpo
VLLM_LORA_DIR=qwen25-3b-dpo-lora
VLLM_MAX_LORA_RANK=8
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.90

# Bind inference to loopback by default. Use an SSH tunnel or authenticated
# reverse proxy instead of exposing the unauthenticated API directly.
VLLM_BIND_ADDRESS=127.0.0.1
VLLM_PORT=8000
